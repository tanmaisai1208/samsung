"""
Battery Management - Final Combined Validation with Best Hyperparameters
======================================================================================
Runs the daily rolling-window XGBoost model using the best hyperparameter
values found from sequential tuning in battery_hypersearch.py:

  n_estimators  = 25   (tuned in step 1)
  max_depth     = 2     (tuned in step 2)
  learning_rate = 0.05  (tuned in step 3)
  subsample     = 0.95   (tuned in step 4)
  colsample_bytree = 0.8 (fixed throughout)

Threshold sweep : ACC_THRESHOLD varied 1→10.
Cosine similarity: computed per day between actual and predicted dSocdt vectors,
                   then averaged per device and across all devices.

NEW — Charging vs Discharging Discrimination Analysis:
  Task A: Does the model's predicted dSocdt distribution for hours that were
          ACTUALLY charging (ground truth dSocdt == 0) look statistically
          different from hours that were actually mild discharge (small
          negative dSocdt)? This checks whether the model has learned to
          tell "no usage / charging" apart from "light usage", rather than
          just predicting values close to zero everywhere.
  Task B: Treat "predicted dSocdt close to zero" as the model's signal for
          "charging is happening this hour", and compare against the actual
          ground-truth charging hours (dSocdt == 0 in wide_csv) using
          precision / recall / F1 — i.e. how good is the model at predicting
          WHEN charging will happen tomorrow, not just how much discharge.

Outputs (all inside results/final_validation/):
  final_predictions_<device>.csv          — per-hour actual vs predicted + cosine sim
  final_summary_all_thresholds.csv        — all thresholds × devices combined
  final_summary_threshold_<T>.csv         — per-device metrics at threshold T
  cosine_similarity_summary.csv           — per-device mean cosine sim + overall mean
  final_validation_plot_<device>.png      — 6-panel grid: actual vs predicted dSocdt
                                             for days sampled every 7 days (covers first
                                             ~48 days). Each panel = one day, clean
                                             side-by-side comparison.
  cosine_similarity_plot.png              — per-device + overall mean cosine sim bar chart
  threshold_accuracy_curve.png            — overall mean accuracy vs threshold value
  charging_discrimination_summary.csv     — per-device separability stats (Task A)
  charging_discrimination_plot.png        — distribution plot: predicted values for
                                             actual-charging vs actual-mild-discharge hours
  charging_event_detection_summary.csv    — per-device precision/recall/F1 (Task B)
  charging_event_detection_plot.png       — confusion-matrix-style bar chart + per-device F1
  charging_zero_threshold_sweep.csv       — F1 at different "near-zero" thresholds
  charging_zero_threshold_sweep_plot.png  — F1 vs zero-threshold curve (helps pick best epsilon)
"""

import os
import glob
import warnings
import numpy as np
import pandas as pd
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from xgboost import XGBRegressor
from sklearn.metrics import (mean_absolute_error, mean_squared_error,
                             precision_score, recall_score, f1_score,
                             confusion_matrix)
from sklearn.multioutput import MultiOutputRegressor

warnings.filterwarnings("ignore")

# ─────────────────────────────────────────────────────────────
# BEST HYPERPARAMETERS
# ─────────────────────────────────────────────────────────────
BEST_PARAMS = {
    "n_estimators"   : 25,
    "max_depth"      : 2,
    "learning_rate"  : 0.05,
    "subsample"      : 0.95,
    "colsample_bytree": 0.8,
    "random_state"   : 42,
    "verbosity"      : 0,
}

# ─────────────────────────────────────────────────────────────
# CONFIGURATION
# ─────────────────────────────────────────────────────────────
WIDE_CSV_FOLDER = "results/wide_csv"
OUTPUT_FOLDER   = "results/xgboost/final_validation"
os.makedirs(OUTPUT_FOLDER, exist_ok=True)

TRAIN_DAYS     = 14
THRESHOLDS     = list(range(1, 11))   # 1, 2, 3, ... 10
DEFAULT_PLOT_T = 2                    # threshold used for per-device plots
HOURS          = list(range(24))

# ── Charging-detection specific settings ────────────────────
# "Actual charging" ground truth = dSocdt exactly 0 in wide_csv (already
# clipped from +ve to 0 upstream, so 0 also includes true charging hours).
# "Actual mild discharge" = small negative values, used for Task A comparison.
MILD_DISCHARGE_UPPER = 0.0    # exclusive upper bound (must be < 0)
MILD_DISCHARGE_LOWER = -1.0   # inclusive lower bound — "small" discharge band

# Task B: a prediction is treated as "predicts charging" if it falls within
# ZERO_EPSILON of 0. This is the main epsilon used for the headline metric.
ZERO_EPSILON = 0.5

# Range of epsilon values swept to show how detection quality changes
# with the definition of "close enough to zero"
ZERO_EPSILON_SWEEP = [0.1, 0.2, 0.3, 0.5, 0.75, 1.0, 1.5, 2.0]

# ─────────────────────────────────────────────────────────────
# COLUMN DEFINITIONS
# ─────────────────────────────────────────────────────────────
DSOCDT_COLS     = [f"dSocdt_h{h}" for h in HOURS]
SOC_COLS        = [f"Soc_h{h}"    for h in HOURS]
DATE_FEAT_COUNT = 4
FEATS_PER_DAY   = len(DSOCDT_COLS) + len(SOC_COLS) + DATE_FEAT_COUNT  # 52


# ─────────────────────────────────────────────────────────────
# FEATURE HELPERS
# ─────────────────────────────────────────────────────────────

def date_feats(date_str):
    ts = pd.Timestamp(date_str)
    return [float(ts.dayofweek), float(ts.day), float(ts.month), float(ts.year)]


def build_feature_row(wide, train_start, train_end):
    feats = []
    for i in range(train_start, train_end):
        feats.extend(wide.iloc[i][DSOCDT_COLS].tolist())
        feats.extend(wide.iloc[i][SOC_COLS].tolist())
        feats.extend(date_feats(wide.index[i]))
    return np.array(feats, dtype=float)


def build_padded_feature_row(wide, context_start, context_end, pad_days):
    feats = [0.0] * (pad_days * FEATS_PER_DAY)
    for i in range(context_start, context_end):
        feats.extend(wide.iloc[i][DSOCDT_COLS].tolist())
        feats.extend(wide.iloc[i][SOC_COLS].tolist())
        feats.extend(date_feats(wide.index[i]))
    return feats


def accuracy_at_threshold(actual, predicted, threshold):
    return float(np.mean(np.abs(actual - predicted) <= threshold)) * 100.0


def cosine_similarity(actual, predicted):
    """
    Cosine similarity between actual and predicted 24-hour dSocdt vectors.
    Range: -1 (opposite) to +1 (identical direction).
    Returns 0.0 if either vector is all-zeros (no discharge activity).
    """
    norm_a = np.linalg.norm(actual)
    norm_p = np.linalg.norm(predicted)
    if norm_a == 0.0 or norm_p == 0.0:
        return 0.0
    return float(np.dot(actual, predicted) / (norm_a * norm_p))


# ─────────────────────────────────────────────────────────────
# DAILY ROLLING PREDICTION  (runs once per device)
# ─────────────────────────────────────────────────────────────

def run_predictions(wide, device_name):
    """
    Returns list of per-day dicts with raw y_actual, y_pred, MAE, RMSE,
    and cosine similarity. Accuracy is computed later per threshold.
    """
    n_days  = len(wide)
    results = []

    model = MultiOutputRegressor(
        XGBRegressor(**BEST_PARAMS),
        n_jobs=-1
    )

    total = n_days - TRAIN_DAYS
    print(f"  Predicting {total} days...")

    for predict_day_idx in range(TRAIN_DAYS, n_days):
        train_start  = predict_day_idx - TRAIN_DAYS
        train_end    = predict_day_idx
        predict_date = wide.index[predict_day_idx]

        X_train, y_train = [], []
        for k in range(1, TRAIN_DAYS):
            pad_days = TRAIN_DAYS - k
            feats  = build_padded_feature_row(wide, train_start,
                                               train_start + k, pad_days)
            target = wide.iloc[train_start + k][DSOCDT_COLS].values.astype(float)
            X_train.append(feats)
            y_train.append(target)

        X_train = np.array(X_train, dtype=float)
        y_train = np.array(y_train, dtype=float)
        model.fit(X_train, y_train)

        X_pred   = build_feature_row(wide, train_start, train_end).reshape(1, -1)
        y_pred   = model.predict(X_pred)[0]
        y_pred   = np.clip(y_pred, a_min=None, a_max=0.0)
        y_actual = wide.iloc[predict_day_idx][DSOCDT_COLS].values.astype(float)

        cos_sim = cosine_similarity(y_actual, y_pred)
        mae     = round(mean_absolute_error(y_actual, y_pred), 6)
        rmse    = round(np.sqrt(mean_squared_error(y_actual, y_pred)), 6)

        results.append({
            "predict_date"   : predict_date,
            "train_start"    : wide.index[train_start],
            "train_end"      : wide.index[train_end - 1],
            "y_actual"       : y_actual,
            "y_pred"         : y_pred,
            "mae"            : mae,
            "rmse"           : rmse,
            "cosine_sim"     : round(cos_sim, 6),
        })

        if (predict_day_idx - TRAIN_DAYS) % 10 == 0 or predict_day_idx == n_days - 1:
            print(f"  Day {predict_day_idx - TRAIN_DAYS + 1:3d}/{total} "
                  f"| {predict_date} | MAE: {mae:.5f} | CosSim: {cos_sim:.4f}")

    return results


# ─────────────────────────────────────────────────────────────
# METRICS
# ─────────────────────────────────────────────────────────────

def metrics_at_threshold(results, threshold):
    daily_accs = [
        accuracy_at_threshold(r["y_actual"], r["y_pred"], threshold)
        for r in results
    ]
    return {
        "mean_accuracy_%": round(float(np.mean(daily_accs)), 4),
        "mean_mae"        : round(float(np.mean([r["mae"]  for r in results])), 6),
        "mean_rmse"       : round(float(np.mean([r["rmse"] for r in results])), 6),
    }


# ─────────────────────────────────────────────────────────────
# NEW — TASK A: ZERO vs SMALL-NEGATIVE DISCRIMINATION
# ─────────────────────────────────────────────────────────────

def charging_discrimination_stats(results):
    """
    For all (day, hour) pairs across the device's predictions, split into
    two groups based on the ACTUAL ground-truth value:
      Group 1 ("actual charging")     : y_actual == 0
      Group 2 ("actual mild discharge"): MILD_DISCHARGE_LOWER <= y_actual < 0

    Then look at what the MODEL PREDICTED for each group. If the model has
    genuinely learned to distinguish charging from light usage, the predicted
    values for Group 1 should be statistically higher (closer to 0) than
    predicted values for Group 2.

    Returns a dict of summary statistics plus the raw arrays for plotting.
    """
    all_actual = np.concatenate([r["y_actual"] for r in results])
    all_pred   = np.concatenate([r["y_pred"]   for r in results])

    charging_mask = (all_actual == 0.0)
    mild_mask     = (all_actual < 0.0) & (all_actual >= MILD_DISCHARGE_LOWER) \
                     & (all_actual < MILD_DISCHARGE_UPPER)

    pred_when_charging = all_pred[charging_mask]
    pred_when_mild      = all_pred[mild_mask]

    n_charging = int(charging_mask.sum())
    n_mild      = int(mild_mask.sum())

    if n_charging == 0 or n_mild == 0:
        return {
            "n_actual_charging_hours"     : n_charging,
            "n_actual_mild_discharge_hours": n_mild,
            "mean_pred_when_charging"     : np.nan,
            "mean_pred_when_mild"         : np.nan,
            "separation_gap"              : np.nan,
            "pred_when_charging"          : pred_when_charging,
            "pred_when_mild"              : pred_when_mild,
        }

    mean_charging = float(np.mean(pred_when_charging))
    mean_mild      = float(np.mean(pred_when_mild))
    # Signed gap: positive means model correctly predicts higher (closer to 0)
    # values for actual-charging hours than for actual-mild-discharge hours.
    # Negative means the model predicts MORE negative values for charging hours
    # than for mild-discharge hours — i.e. it has learned an INVERTED signal,
    # likely because heavy discharge momentum from the previous day often
    # precedes a charging event (low battery -> user plugs in), so the model
    # associates "strong recent discharge" with both "more discharge tomorrow"
    # AND coincidentally with hours that turn out to be charging.
    gap = mean_charging - mean_mild
    abs_gap = abs(gap)

    return {
        "n_actual_charging_hours"      : n_charging,
        "n_actual_mild_discharge_hours": n_mild,
        "mean_pred_when_charging"      : round(mean_charging, 6),
        "std_pred_when_charging"       : round(float(np.std(pred_when_charging)), 6),
        "mean_pred_when_mild"          : round(mean_mild, 6),
        "std_pred_when_mild"           : round(float(np.std(pred_when_mild)), 6),
        "separation_gap"               : round(gap, 6),
        "abs_separation_gap"           : round(abs_gap, 6),
        "direction"                    : ("CORRECT (charging closer to 0)" if gap > 0
                                          else "INVERTED (charging more negative)"),
        "pred_when_charging"           : pred_when_charging,
        "pred_when_mild"               : pred_when_mild,
    }


def plot_charging_discrimination(per_device_stats, plot_path):
    """
    Box/violin-style comparison: for each device, show the distribution of
    predicted dSocdt for (a) hours that were actually charging vs
    (b) hours that were actually mild discharge.

    If boxes are well separated → model distinguishes charging from light use.
    If boxes overlap heavily → model treats near-zero values as one blur.
    """
    devices = list(per_device_stats.keys())
    n_dev   = len(devices)

    fig, ax = plt.subplots(figsize=(max(12, n_dev * 1.3), 7))

    positions_charging = np.arange(n_dev) * 2.2
    positions_mild      = positions_charging + 0.9

    box_data_charging, box_data_mild = [], []
    for dev in devices:
        s = per_device_stats[dev]
        bc = s["pred_when_charging"]
        bm = s["pred_when_mild"]
        box_data_charging.append(bc if len(bc) > 0 else [np.nan])
        box_data_mild.append(bm if len(bm) > 0 else [np.nan])

    bp1 = ax.boxplot(box_data_charging, positions=positions_charging, widths=0.7,
                     patch_artist=True, showfliers=False)
    bp2 = ax.boxplot(box_data_mild, positions=positions_mild, widths=0.7,
                     patch_artist=True, showfliers=False)

    for patch in bp1["boxes"]:
        patch.set_facecolor("steelblue")
        patch.set_alpha(0.7)
    for patch in bp2["boxes"]:
        patch.set_facecolor("salmon")
        patch.set_alpha(0.7)

    ax.axhline(0, color="black", linewidth=0.8, linestyle="-")
    mid_positions = (positions_charging + positions_mild) / 2
    short_names = [d[:12] + "…" if len(d) > 12 else d for d in devices]
    ax.set_xticks(mid_positions)
    ax.set_xticklabels(short_names, rotation=30, ha="right", fontsize=8)
    ax.set_ylabel("Predicted dSocdt", fontsize=11)
    ax.set_title(
        "Predicted dSocdt: Actual-Charging Hours vs Actual-Mild-Discharge Hours\n"
        "(blue = model's prediction when truth was charging/idle (dSocdt=0)  |  "
        "red = model's prediction when truth was mild discharge "
        f"({MILD_DISCHARGE_LOWER} to 0))\n"
        "Note: if blue boxes sit BELOW red boxes, the model has learned an "
        "inverted signal — it predicts stronger discharge right before charging,\n"
        "likely because heavy recent usage often precedes the user plugging in the device.",
        fontsize=10, fontweight="bold"
    )
    legend_elems = [
        mpatches.Patch(facecolor="steelblue", alpha=0.7, label="Predicted value — actual charging hours"),
        mpatches.Patch(facecolor="salmon",    alpha=0.7, label="Predicted value — actual mild discharge hours"),
    ]
    ax.legend(handles=legend_elems, fontsize=9, loc="lower right")
    ax.grid(axis="y", linestyle="--", alpha=0.4)

    fig.tight_layout()
    fig.savefig(plot_path, dpi=150, bbox_inches="tight")
    plt.close(fig)
    print(f"  Charging discrimination plot saved  →  {plot_path}")


# ─────────────────────────────────────────────────────────────
# NEW — TASK B: CHARGING EVENT DETECTION (precision/recall/F1)
# ─────────────────────────────────────────────────────────────

def charging_event_detection_stats(results, epsilon=ZERO_EPSILON):
    """
    Binary classification framing:
      Ground truth positive  = actual dSocdt == 0   (charging/idle hour)
      Predicted positive     = |predicted dSocdt| <= epsilon  (model "thinks"
                                this hour is charging/idle)

    Returns precision, recall, F1, and confusion matrix counts, computed
    over all (day, hour) pairs pooled together for this device.
    """
    all_actual = np.concatenate([r["y_actual"] for r in results])
    all_pred   = np.concatenate([r["y_pred"]   for r in results])

    y_true = (all_actual == 0.0).astype(int)
    y_pred = (np.abs(all_pred) <= epsilon).astype(int)

    # Handle edge case: all one class
    if y_true.sum() == 0 or y_true.sum() == len(y_true):
        precision = recall = f1 = np.nan
        tn = fp = fn = tp = 0
    else:
        precision = precision_score(y_true, y_pred, zero_division=0)
        recall    = recall_score(y_true, y_pred, zero_division=0)
        f1        = f1_score(y_true, y_pred, zero_division=0)
        cm = confusion_matrix(y_true, y_pred, labels=[0, 1])
        tn, fp, fn, tp = cm.ravel()

    return {
        "epsilon"                : epsilon,
        "n_actual_charging_hours": int(y_true.sum()),
        "n_total_hours"          : int(len(y_true)),
        "n_pred_charging_hours"  : int(y_pred.sum()),
        "precision"              : round(float(precision), 4) if not np.isnan(precision) else np.nan,
        "recall"                 : round(float(recall), 4) if not np.isnan(recall) else np.nan,
        "f1_score"                : round(float(f1), 4) if not np.isnan(f1) else np.nan,
        "true_positive"          : int(tp),
        "false_positive"         : int(fp),
        "true_negative"          : int(tn),
        "false_negative"         : int(fn),
    }


def plot_charging_event_detection(detection_df, plot_path):
    """
    Bar chart: precision, recall, F1 per device at the default epsilon,
    plus overall mean line.
    """
    dev_data = detection_df[detection_df["device"] != "OVERALL_MEAN"].copy()
    overall  = detection_df[detection_df["device"] == "OVERALL_MEAN"]

    short_names = [d[:12] + "…" if len(d) > 12 else d for d in dev_data["device"]]
    x = np.arange(len(dev_data))
    width = 0.25

    fig, ax = plt.subplots(figsize=(max(12, len(dev_data) * 1.4), 6.5))
    ax.bar(x - width, dev_data["precision"], width, label="Precision",
           color="steelblue", edgecolor="white")
    ax.bar(x,          dev_data["recall"],    width, label="Recall",
           color="darkorange", edgecolor="white")
    ax.bar(x + width,  dev_data["f1_score"],   width, label="F1-score",
           color="seagreen", edgecolor="white")

    if not overall.empty:
        ax.axhline(overall["f1_score"].values[0], color="crimson",
                   linestyle="--", linewidth=1.8,
                   label=f"Overall mean F1: {overall['f1_score'].values[0]:.3f}")

    ax.set_xticks(x)
    ax.set_xticklabels(short_names, rotation=30, ha="right", fontsize=8)
    ax.set_ylabel("Score", fontsize=11)
    ax.set_ylim(0, 1.1)
    ax.set_title(
        f"Charging Event Detection — Precision / Recall / F1 per Device\n"
        f"('Predicted charging' = |predicted dSocdt| ≤ {ZERO_EPSILON})",
        fontsize=12, fontweight="bold"
    )
    ax.legend(fontsize=9)
    ax.grid(axis="y", linestyle="--", alpha=0.4)
    fig.tight_layout()
    fig.savefig(plot_path, dpi=150, bbox_inches="tight")
    plt.close(fig)
    print(f"  Charging event detection plot saved  →  {plot_path}")


def plot_epsilon_sweep(sweep_df, plot_path):
    """
    Line plot: F1 score vs the epsilon threshold used to define
    "predicted charging" (|predicted dSocdt| <= epsilon).
    Helps decide the most meaningful epsilon for charging detection.
    """
    devices = sweep_df["device"].unique()
    epsilons = sorted(sweep_df["epsilon"].unique())

    fig, ax = plt.subplots(figsize=(10, 6))
    cmap = plt.cm.tab10
    all_f1 = []
    for di, dev in enumerate(devices):
        dev_df = sweep_df[sweep_df["device"] == dev].sort_values("epsilon")
        f1s    = dev_df["f1_score"].values
        short  = dev[:14] + "…" if len(dev) > 14 else dev
        ax.plot(epsilons, f1s, marker="o", linewidth=1.2, alpha=0.5,
                color=cmap(di % 10), label=short)
        all_f1.append(f1s)

    overall = np.nanmean(all_f1, axis=0)
    ax.plot(epsilons, overall, marker="D", linewidth=2.5, color="black",
            label="Overall mean F1", zorder=5)
    best_eps_idx = int(np.nanargmax(overall))
    ax.axvline(epsilons[best_eps_idx], color="crimson", linestyle="--",
               linewidth=1.5,
               label=f"Best epsilon = {epsilons[best_eps_idx]} (F1={overall[best_eps_idx]:.3f})")

    ax.set_xlabel("Epsilon (|predicted dSocdt| ≤ epsilon → 'predicted charging')",
                  fontsize=11)
    ax.set_ylabel("F1-score", fontsize=11)
    ax.set_title("Charging Detection F1-score vs Zero-Threshold (Epsilon)\n"
                 "(how the choice of 'near zero' definition affects detection quality)",
                 fontsize=12, fontweight="bold")
    ax.legend(fontsize=7, ncol=3, loc="lower right")
    ax.grid(linestyle="--", alpha=0.4)
    fig.tight_layout()
    fig.savefig(plot_path, dpi=150, bbox_inches="tight")
    plt.close(fig)
    print(f"  Epsilon sweep plot saved  →  {plot_path}")


# ─────────────────────────────────────────────────────────────
# PER-DEVICE PLOT
# ─────────────────────────────────────────────────────────────

def plot_device(results, device_name, plot_path, threshold=DEFAULT_PLOT_T):
    """
    Per-device plot showing ONLY actual vs predicted dSocdt, as a grid of
    up to 6 separate subplots — one subplot per sampled day, sampled every
    7 days (covering at most the first 48 days). Each subplot shows that
    single day's actual (solid) and predicted (dashed) 24-hour dSocdt curve,
    avoiding the clutter of overlaying many days on one axes.
    """
    SAMPLE_STEP  = 7
    MAX_PANELS   = 6

    sample_idx = list(range(0, min(len(results), SAMPLE_STEP * MAX_PANELS), SAMPLE_STEP))
    sample_idx = sample_idx[:MAX_PANELS]

    n_panels = len(sample_idx)
    n_cols   = 3
    n_rows   = int(np.ceil(n_panels / n_cols))

    fig, axes = plt.subplots(n_rows, n_cols, figsize=(18, 5 * n_rows))
    axes = np.array(axes).reshape(-1)   # flatten regardless of shape

    fig.suptitle(
        f"Actual vs Predicted dSocdt — {device_name}\n"
        f"n_estimators={BEST_PARAMS['n_estimators']}  "
        f"max_depth={BEST_PARAMS['max_depth']}  "
        f"lr={BEST_PARAMS['learning_rate']}  "
        f"subsample={BEST_PARAMS['subsample']}",
        fontsize=12, fontweight="bold"
    )

    for panel_i, idx in enumerate(sample_idx):
        ax = axes[panel_i]
        r  = results[idx]

        ax.plot(HOURS, r["y_actual"], color="steelblue", linewidth=2.0,
                marker="o", markersize=3, label="Actual")
        ax.plot(HOURS, r["y_pred"],   color="crimson",   linewidth=2.0,
                linestyle="--", marker="s", markersize=3, label="Predicted")

        day_acc = accuracy_at_threshold(r["y_actual"], r["y_pred"], threshold)
        ax.set_title(
            f"{r['predict_date']}   |   Acc(T={threshold})={day_acc:.1f}%   |   "
            f"MAE={r['mae']:.3f}   |   CosSim={r['cosine_sim']:.3f}",
            fontsize=9.5
        )
        ax.set_xlabel("Hour of day", fontsize=9)
        ax.set_ylabel("dSocdt", fontsize=9)
        ax.set_xticks(range(0, 24, 4))
        ax.legend(fontsize=8, loc="lower left")
